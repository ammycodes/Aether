# ==========================================
# AI Agent Orchestration Platform config
# ==========================================

# Port and server host
PORT=8000
HOST=127.0.0.1

# Database Configuration (Defaults to local SQLite file)
DATABASE_URL=sqlite:///./agents.db

# LLM Provider Keys
# Set these to enable real LLM execution. 
# If left empty, Aether Runtime runs in intelligent Offline/Hybrid Mode!
GEMINI_API_KEY=
OPENAI_API_KEY=

# Telegram Bot Integration
# Get a token from @BotFather in Telegram.
# Once supplied, your agents will be live and reachable via Telegram!
TELEGRAM_BOT_TOKEN=
